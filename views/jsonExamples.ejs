function renderExample(title, linkId, info, data, url, id, hash){

  return `<div class="json-example">
        <h3 id="${linkId}">
          	${title}
        </h3>
        <div class="json-info">
          	${info} 
        </div>
        <div class="json-link-example">
           https://example.com/api/json/${url}${id}
        </div>
        <div class="json-link-example">
            https://example.com/api/json/${url}${hash}
        </div>
        <code>${data}</code>
    </div>`;
}

