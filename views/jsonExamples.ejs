    class JSONExample{

		constructor(parent, category, title, linkId, info, data, exampleLinks){

			this.parent = parent;
			this.category = category;
			this.title = title;
			this.linkId = linkId;
			this.info = info;
			this.data = data;
			this.exampleLinks = exampleLinks;

			this.wrapper = UIDiv("hidden");

			this.parent.append(this.wrapper);
			this.create();
			this.render(this.category);
		}

		create(){

			const header = document.createElement("h3");
			header.id = this.linkId;
			header.append(this.title);

			const info = UIDiv("json-info");
			info.append(this.info);

			this.wrapper.append(header, info);

			for(let i = 0; i < this.exampleLinks.length; i++){

				const e = this.exampleLinks[i];

				const elem = UIDiv("json-link-example");
				elem.append(`https://example.com/api/json/${e}`);

				this.wrapper.append(elem);
			}

			const exampleOutput = document.createElement("code");
			exampleOutput.append(this.data);

			this.wrapper.append(exampleOutput);
		}

		render(newMode){

			console.log(this.category, newMode);

			if(this.category === newMode){
				this.wrapper.className = "json-example";
			}else{
				this.wrapper.className = "hidden";
			}
		}
    }

    class ExampleManager{

        constructor(){

            this.parent = document.querySelector("#root");
            this.mode = "<%= mode %>";

            UIHeader(this.parent, "JSON Examples");
            this.createTabs();

			this.examples = [
				new JSONExample(
					this.parent, 
					"match", 
					"Basic", 
					"basic", 
					"Returns data about the match such as server, gametype, map, total players, total teams, winners.", 
					basicMatch, 
					[
						"match/basic/?id=187", 
						"match/basic/?id=ca5eda2e6a2e49c3a4707aac1c7d19be"
					]
				),
        new JSONExample(
					this.parent, 
					"match", 
					"Detailed", 
					"detailed", 
					"Returns full data about the match, includes mutators, gamespeed, and bHardcore.", 
					matchDetailed, 
					[
						"match/detailed/?id=187", 
						"match/detailed/?id=ca5eda2e6a2e49c3a4707aac1c7d19be"
					]
				),
				new JSONExample(
					this.parent, 
					"match", 
					"Players Basic", 
					"players-basic", 
					"Returns all players in match, includes: id, hash, name, team, playtime, score, kills, frags, deaths, match result.", 
					matchPlayersBasic, 
					[
						"match/players-basic/?id=187", 
						"match/players-basic/?id=ca5eda2e6a2e49c3a4707aac1c7d19be"
					]
				),
				new JSONExample(
					this.parent, 
					"match", 
					"Players Full", 
					"players-full", 
					"Returns detailed data for every player(spectators are ignored), this includes CTF stats and Domination stats if applicable.", 
					playersFullData, 
					[
						"match/players-full/?id=187", 
						"match/players-full/?id=ca5eda2e6a2e49c3a4707aac1c7d19be"
					]
				),
				new JSONExample(
					this.parent, 
					"match", 
					"Kills Detailed", 
					"kills-detailed", 
					"Returns player list, player kills match up, every kill, and team kill, including what weapon both players had at the time.", 
					matchKillsDetailed, 
					[
						"match/kills-detailed/?id=187", 
						"match/kills-detailed/?id=ca5eda2e6a2e49c3a4707aac1c7d19be"
					]
				),
				new JSONExample(
					this.parent, 
					"match", 
					"Kills Basic", 
					"kills-basic", 
					"Returns player list, every kill, and team kill.", 
					matchKillsBasic, 
					[
						"match/kills-basic/?id=187", 
						"match/kills-basic/?id=ca5eda2e6a2e49c3a4707aac1c7d19be"
					]
				)
			];

			this.render();
        }

    	createTabs(){

			const options = [
				{"display": "Match", "value": "match"},
				{"display": "testttt", "value": "t"},
			];

			this.tabs = new UITabs(this.parent, options, this.mode);

			this.tabs.wrapper.addEventListener("tabChanged", (e) =>{

				history.pushState(null, "", `/jsonexamples/?mode=${e.detail.newTab}`);
				this.mode = e.detail.newTab;
				this.render();
			});
		}


		render(){

			for(let i = 0; i < this.examples.length; i++){
				
				const e = this.examples[i];

				e.render(this.mode);
			}
		}
	}


	new ExampleManager();
</script>

