<div id="root">

	<div class="info">
        View examples of the various JSON API commands.
    </div>
    <div class="header-wrapper" id="match">
        Match Examples
    </div>
    <div class="info">
        When fetching match data you can use either the match id, or the match perma link hash.
    </div>
  	<%- 
		renderExample(
			"Basic",
			"match-basic", 
			"Returns data about the match such as server, gametype, map, total players, total teams, winners.",
			basicMatch, 
			`match/basic/?id=`, 
			187, 
			"ca5eda2e6a2e49c3a4707aac1c7d19be"
		); 
	%> 
	<%-
	renderExample(
			"Players Full",
			"match-players-full", 
			"Returns detailed data for every player(spectators are ignored), this includes CTF stats and Domination stats if applicable.",
			playersFullData, 
			`match/players-full/?id=`, 
			187, 
			"ca5eda2e6a2e49c3a4707aac1c7d19be"
		); 
	%>
	<%-
	renderExample(
			"Kills Basic",
			"match-kills-basic", 
			"Returns player list, every kill, and team kill.",
			matchKillsBasic, 
			`match/kills-basic/?id=`, 
			187, 
			"ca5eda2e6a2e49c3a4707aac1c7d19be"
		); 
	%>

	<%-
	renderExample(
			"Kills Detailed",
			"match-kills-detailed", 
			"Returns player list, every kill, and team kill, including what weapon both players had at the time.",
			matchKillsDetailed, 
			`match/kills-detailed/?id=`, 
			187, 
			"ca5eda2e6a2e49c3a4707aac1c7d19be"
		); 
	%>
</div>

<script>


	class JSONExample{

		//title, linkId, info, data, url, id, hash
		constructor(parent, category, title, linkId, info, data, exampleLinks){

			this.parent = parent;
			this.category = category;
			this.title = title;
			this.linkId = linkId;
			this.info = info;
			this.data = data;
			this.exampleLinks = exampleLinks;

			this.wrapper = UIDiv("json-example");

			this.parent.append(this.wrapper);
			this.render();
		}

		render(){

			const header = document.createElement("h3");
			header.id = this.linkId;
			header.append(this.title);

			const info = UIDiv("json-info");
			info.append(this.info);

			this.wrapper.append(header, info);

			for(let i = 0; i < this.exampleLinks.length; i++){

				const e = this.exampleLinks[i];

				const elem = UIDiv("json-link-example");
				elem.append(`https://example.com/api/json/${e}`);

				this.wrapper.append(elem);
			}

			const exampleOutput = document.createElement("code");
			exampleOutput.append(this.data);

			this.wrapper.append(exampleOutput);
			
			return;
		this.wrapper.innerHTML = `
			
				
				<div class="json-link-example">
				https://example.com/api/json/urlid
				</div>
				<div class="json-link-example">
					https://example.com/api/json/urlhash
				</div>
				<code>ghfhfghgfghf</code>`;
		}
	}

	class ExampleManager{

		constructor(){

			this.parent = document.querySelector("#root");
			this.mode = "match";

			UIHeader(this.parent, "JSON Examples");
			this.createTabs();

			new JSONExample(this.parent, "test", "TITLE", "LINKID", "test info", `{
    "id": 187,
    "date": "2026-03-03T14:53:55.000Z",
    "hash": "ca5eda2e6a2e49c3a4707aac1c7d19be",
    "server": "Horse Noise 60tr",
    "gametype": "Tournament Team Game",
    "map": "DM-SpaceNoxx",
    "playtime": 59.1727,
    "players": 32,
    "winners": [
        "Red"
    ],
    "bInstagib": false,
    "teams": 2,
    "redTeamScore": 19,
    "blueTeamScore": 2,
    "greenTeamScore": 0,
    "yellowTeamScore": 0
}`, ["match/basic/?id=187", "match/basic/?id=ca5eda2e6a2e49c3a4707aac1c7d19be"]);
		}

		createTabs(){

			const options = [
				{"display": "Match", "value": "match"},
				{"display": "testttt", "value": "t"},
			];

			this.tabs = new UITabs(this.parent, options, this.mode, (e) =>{
				console.log(e);
			});
		}
	}


	new ExampleManager();
</script>

